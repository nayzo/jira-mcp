# Jira MCP — Environment variables
# Copy to .env and fill in your values
# ⚠️ Never commit .env

# Jira Cloud connection
JIRA_HOST=your-company.atlassian.net
JIRA_USERNAME=your.email@company.com
JIRA_API_TOKEN=your_api_token

# Jira project
JIRA_PROJECT_KEY=ALM

# Custom fields (optional — adjust to your Jira instance)
JIRA_STORY_POINTS_FIELD=customfield_10040
JIRA_ACCEPTANCE_CRITERIA_FIELD=customfield_10429
JIRA_EPIC_LINK_FIELD=customfield_10014
JIRA_PRODUCT_FIELD=
JIRA_PRODUCT_VALUE=
JIRA_PRODUCT_ID=
JIRA_CATEGORY_FIELD=
JIRA_DEFAULT_CATEGORY_ID=
JIRA_DEFAULT_CATEGORY_VALUE=
JIRA_ALTERNATE_CATEGORY_ID=
JIRA_ALTERNATE_CATEGORY_VALUE=
USE_ALTERNATE_CATEGORY=false

# Zephyr Scale integration
ZEPHYR_API_TOKEN=your_zephyr_api_token

# Behaviour
AUTO_CREATE_TEST_TICKETS=true
